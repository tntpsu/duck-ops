{
  "version": 1,
  "platform_scope": [
    "instagram"
  ],
  "collection_boundary": {
    "mode": "public_observe_only",
    "login_allowed": false,
    "interaction_allowed": false,
    "bounded_scroll_only": true,
    "autoplay_allowed": false,
    "max_accounts_per_run": 10,
    "latest_posts_per_account": 12,
    "refresh_bucket_count": 4,
    "force_refresh_after_hours": 96,
    "profile_only_backoff_hours": 168,
    "max_live_canary_targets": 1,
    "notes": [
      "Collect only public-facing competitor snapshots in the first slice.",
      "Do not like, follow, comment, or log in.",
      "Keep competitor social observations separate from our own post truth.",
      "Refresh accounts on a staggered daily cadence to reduce Instagram rate-limit pressure.",
      "If an account only yields HTML profile metadata and no post timeline, back it off for a week before retrying.",
      "Allow at most one bounded live canary target per run for non-forced competitor refreshes."
    ]
  },
  "snapshot_schema": {
    "required_fields": [
      "account_name",
      "platform",
      "account_handle",
      "post_url",
      "observed_at",
      "post_date",
      "hour_bucket",
      "post_format",
      "visible_hook",
      "theme",
      "duck_family",
      "engagement_visible",
      "repeated_motif"
    ],
    "optional_fields": [
      "post_id",
      "account_url",
      "caption_excerpt",
      "notes",
      "confidence",
      "visible_likes",
      "visible_comments",
      "source_url",
      "hook_family"
    ],
    "comparison_dimensions": [
      "post_format",
      "theme",
      "hour_bucket",
      "duck_family",
      "hook_family"
    ]
  },
