{
  "version": 1,
  "platform_scope": [
    "instagram"
  ],
  "collection_boundary": {
    "mode": "public_observe_only",
    "login_allowed": false,
    "interaction_allowed": false,
    "bounded_scroll_only": true,
    "autoplay_allowed": false,
    "max_accounts_per_run": 10,
    "latest_posts_per_account": 12,
    "notes": [
      "Collect only public-facing competitor snapshots in the first slice.",
      "Do not like, follow, comment, or log in.",
      "Keep competitor social observations separate from our own post truth."
    ]
  },
  "snapshot_schema": {
    "required_fields": [
      "account_name",
      "platform",
      "account_handle",
      "post_url",
      "observed_at",
      "post_date",
      "hour_bucket",
      "post_format",
      "visible_hook",
      "theme",
      "duck_family",
      "engagement_visible",
      "repeated_motif"
    ],
    "optional_fields": [
      "post_id",
      "account_url",
      "caption_excerpt",
      "notes",
      "confidence",
      "visible_likes",
      "visible_comments",
      "source_url",
      "hook_family"
    ],
    "comparison_dimensions": [
      "post_format",
      "theme",
      "hour_bucket",
      "duck_family",
      "hook_family"
    ]
  },
