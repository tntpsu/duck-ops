{
  "version": 1,
  "mode": "standalone_notifier",
  "env_file": "/Users/philtullai/ai-agents/duckAgent/.env",
  "smtp": {
    "host_env_precedence": [
      "SMTP_HOST"
    ],
    "port_env_precedence": [
      "SMTP_PORT"
    ],
    "user_env_precedence": [
      "SMTP_USER"
    ],
